{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT-DLP Desktop",
  "version": "0.2.0",
  "identifier": "com.ytdlp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "YT-DLP Desktop",
        "width": 820,
        "height": 680,
        "minWidth": 640,
        "minHeight": 520,
        "center": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' http: https: data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' http: https: ipc: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}